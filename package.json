{
  "name": "reveal-ui",
  "version": "0.1.0",
  "description": "Persistent-summary disclosure primitives for inline reveal editors, expanding card disclosure, and nested reveal flows.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HackEAC/reveal-ui.git"
  },
  "homepage": "https://github.com/HackEAC/reveal-ui#readme",
  "bugs": {
    "url": "https://github.com/HackEAC/reveal-ui/issues"
  },
  "keywords": [
    "react",
    "disclosure",
    "persistent-summary disclosure",
    "inline reveal editor",
    "expanding card disclosure",
    "accordion",
    "motion"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "npm run build:clean && npm run build:esm && npm run build:cjs && npm run build:types && npm run build:cjs-package",
    "build:clean": "rm -rf dist",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:cjs-package": "node ./scripts/write-cjs-package.mjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "pack:local": "npm pack",
    "smoke": "node ./scripts/smoke-consumer.mjs",
    "example:install": "npm install --prefix ./examples/next-app",
    "example:dev": "npm run dev --prefix ./examples/next-app",
    "ci": "npm run lint && npm run test && npm run typecheck && npm run build && npm run pack:dry-run && npm run smoke",
    "docs:build": "npm run build --prefix ./examples/next-app",
    "docs:install": "npm ci --prefix ./examples/next-app",
    "docs:preview": "npm run dev --prefix ./examples/next-app",
    "prepack": "npm run build",
    "prepublishOnly": "npm run ci"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.2.4",
    "clsx": "2.1.1",
    "tailwind-merge": "3.5.0"
  },
  "peerDependencies": {
    "motion": "^12.34.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "npm@11.9.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "motion": "^12.37.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
